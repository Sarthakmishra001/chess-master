<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chess Master</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at center, #1a1a1a 0%, #000000 100%);
            overflow-x: hidden;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            width: 100%;
            max-width: 650px;
            padding: 0.5rem !important;
        }

        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            grid-template-rows: repeat(8, 1fr);
            width: 100%;
            max-width: 500px;
            aspect-ratio: 1 / 1;
            border: 8px solid #2d2d2d;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            background-color: #1a1a1a;
        }

        .square {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .square.light {
            background-color: #f0d9b5;
        }

        .square.dark {
            background-color: #b58863;
        }

        .piece {
            font-size: clamp(24px, 6vw, 48px);
            cursor: move;
            transition: transform 0.2s ease;
            user-select: none;
        }

        .piece:hover {
            transform: scale(1.1);
        }

        .piece.white {
            color: #ffffff;
            text-shadow: 0 0 2px rgba(0, 0, 0, 0.5);
        }

        .piece.black {
            color: #1a1a1a;
            filter: drop-shadow(0 0 1px rgba(255, 255, 255, 0.3));
        }

        .flipped {
            transform: rotate(180deg);
        }

        .flipped .piece {
            transform: rotate(180deg);
        }

        .dragging {
            opacity: 0.5;
        }

        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.3);
        }
        /* Game Over Modal */
        #game-over-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 100;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: rgba(30, 30, 30, 0.95);
            border: 2px solid rgba(255, 255, 255, 0.1);
            padding: 3rem;
            border-radius: 24px;
            text-align: center;
            box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
            max-width: 400px;
            width: 90%;
        }
    </style>
</head>
<body class="text-white">
    <!-- Promotion Modal -->
    <div id="promotion-modal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md z-[110] flex items-center justify-center">
        <div class="modal-content">
            <h2 class="text-2xl font-bold mb-6 text-white">Choose Promotion</h2>
            <div class="flex gap-4 justify-center">
                <button onclick="selectPromotion('q')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♕</button>
                <button onclick="selectPromotion('r')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♖</button>
                <button onclick="selectPromotion('b')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♗</button>
                <button onclick="selectPromotion('n')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♘</button>
            </div>
        </div>
    </div>

    <!-- Game Over Modal -->
    <div id="game-over-modal">
        <div class="modal-content">
            <h2 class="text-3xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-yellow-400 to-orange-500">Game Over</h2>
            <p id="winner-message" class="text-xl mb-8 text-zinc-300"></p>
            <button onclick="resetGame()" class="px-6 py-2 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full font-bold hover:scale-105 transition-transform">Play Again</button>
        </div>
    </div>

    <div class="min-h-screen flex flex-col items-center justify-center p-4">
        <header class="mb-4 text-center">
            <h1 class="text-2xl md:text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500">Chess Master</h1>
            <div class="mt-2">
                <a href="/match-history" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors underline underline-offset-4">View Match History</a>
            </div>
        </header>

        <div class="mb-4 flex gap-8 text-lg font-mono font-bold tracking-wider">
            <div id="white-timer" class="px-4 py-1 rounded bg-white text-black shadow-[0_0_15px_rgba(255,255,255,0.3)]">White: 05:00</div>
            <div id="black-timer" class="px-4 py-1 rounded bg-black text-white border border-zinc-700 shadow-[0_0_15px_rgba(0,0,0,0.5)]">Black: 05:00</div>
        </div>

        <div class="w-full max-w-6xl flex flex-col items-center justify-center gap-6">
            <!-- Chessboard Container -->
            <div class="glass-panel">
                <div class="chessboard"></div>
            </div>

            <!-- Move History Sidebar -->
            <div class="glass-panel w-full md:w-64 h-80 md:h-[600px] flex flex-col">
                <h3 class="text-sm font-bold uppercase tracking-widest mb-4 text-center text-zinc-400">Move History</h3>
                <div id="move-history" class="flex-1 overflow-y-auto pr-2 custom-scrollbar">
                    <div class="grid grid-cols-[30px_1fr_1fr] gap-x-2 gap-y-1 text-sm font-mono" id="history-content">
                        <!-- Moves will be injected here -->
                    </div>
                </div>
            </div>
        </div>

        <div class="w-full max-w-6xl mt-6 flex justify-center">
            <!-- Game Info Bottom -->
            <div id="game-info" class="flex flex-wrap justify-center gap-4 text-xs font-semibold uppercase tracking-wider">
                <div id="role-display" class="px-4 py-2 rounded-lg bg-zinc-800/50 border border-zinc-700/50 backdrop-blur-md shadow-lg min-w-[120px] text-center">Connecting...</div>
                <div id="turn-display" class="px-4 py-2 rounded-lg bg-zinc-800/50 border border-zinc-700/50 backdrop-blur-md shadow-lg min-w-[120px] text-center">Waiting...</div>
                <div id="spectator-display" class="px-4 py-2 rounded-lg bg-zinc-800/50 border border-zinc-700/50 backdrop-blur-md shadow-lg min-w-[100px] text-center">Spectators: 0</div>
            </div>
        </div>

        <footer class="mt-8 text-zinc-500 text-xs">
            Developed by Sarthak❤️ for Chess Lovers.
        </footer>
    </div>

    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js" integrity="sha384-2huaZvOR9iDzHqslqwpR87isEmrfxqyWOF7hr7BY6KG0+hVKLoEXMPUJw3ynWuhO" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js" integrity="sha512-xRllwz2gdZciIB+AkEbeq+gVhX8VB8XsfqeFbUh+SzHlN96dEduwtTuVuc2u9EROlmW9+yhRlxjif66ORpsgVA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="/javascripts/chess_Game.js"></script>
    <script>
        // Update UI based on game state
        socket.on("playerRole", function (role) {
            document.getElementById("role-display").innerText = "Role: " + (role === "w" ? "White" : "Black");
        });
        socket.on("spectatorRole", function () {
            document.getElementById("role-display").innerText = "Role: Spectator";
        });
        socket.on("boardState", function (fen) {
            const turn = fen.split(" ")[1];
            document.getElementById("turn-display").innerText = "Turn: " + (turn === "w" ? "White" : "Black");
            document.getElementById("game-over-modal").style.display = "none";
        });
        socket.on("move", function (move) {
            const turn = chess.turn();
            document.getElementById("turn-display").innerText = "Turn: " + (turn === "w" ? "White" : "Black");
        });
        socket.on("spectatorCount", function (count) {
            document.getElementById("spectator-display").innerText = "Spectators: " + count;
        });
    </script>
</body>
</html>
