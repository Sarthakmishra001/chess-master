<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chess Master</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js" integrity="sha384-2huaZvOR9iDzHqslqwpR87isEmrfxqyWOF7hr7BY6KG0+hVKLoEXMPUJw3ynWuhO" crossorigin="anonymous"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at center, #1a1a1a 0%, #000000 100%);
            overflow-x: hidden;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            width: 100%;
            padding: 0.5rem !important;
        }

        .chessboard {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            grid-template-rows: repeat(8, 1fr);
            width: 100%;
            aspect-ratio: 1 / 1;
            margin: 0 auto;
            border: 6px solid #2d2d2d;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.6);
            background-color: #1a1a1a;
        }

        .square {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .square.light {
            background-color: #f0d9b5;
        }

        .square.dark {
            background-color: #b58863;
        }

        .piece {
            font-size: clamp(22px, 5.5vw, 46px);
            cursor: move;
            transition: transform 0.2s ease;
            user-select: none;
        }

        .piece:hover {
            transform: scale(1.1);
        }

        .piece.white {
            color: #ffffff;
            text-shadow: 0 0 2px rgba(0, 0, 0, 0.5);
        }

        .piece.black {
            color: #1a1a1a;
            filter: drop-shadow(0 0 1px rgba(255, 255, 255, 0.3));
        }

        .flipped {
            transform: rotate(180deg);
        }

        .flipped .piece {
            transform: rotate(180deg);
        }

        .dragging {
            opacity: 0.5;
        }

        /* Custom Scrollbar */
        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.3);
        }
        /* Game Over Modal */
        #game-over-modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            z-index: 100;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: rgba(30, 30, 30, 0.95);
            border: 2px solid rgba(255, 255, 255, 0.1);
            padding: 3rem;
            border-radius: 24px;
            text-align: center;
            box-shadow: 0 0 50px rgba(0, 0, 0, 0.5);
            max-width: 400px;
            width: 90%;
        }
    </style>
</head>
<body class="text-white">
    <% if (locals.matchId) { %>
    <!-- Promotion Modal -->
    <div id="promotion-modal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md z-[110] flex items-center justify-center">
        <div class="modal-content">
            <h2 class="text-2xl font-bold mb-6 text-white">Choose Promotion</h2>
            <div class="flex gap-4 justify-center">
                <button onclick="selectPromotion('q')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♕</button>
                <button onclick="selectPromotion('r')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♖</button>
                <button onclick="selectPromotion('b')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♗</button>
                <button onclick="selectPromotion('n')" class="p-4 bg-zinc-800 hover:bg-zinc-700 rounded-xl text-4xl transition-all hover:scale-110">♘</button>
            </div>
        </div>
    </div>

    <!-- Game Over Modal -->
    <div id="game-over-modal">
        <div class="modal-content">
            <h2 class="text-3xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-yellow-400 to-orange-500">Game Over</h2>
            <p id="winner-message" class="text-xl mb-8 text-zinc-300"></p>
            <button onclick="resetGame()" class="px-6 py-2 bg-gradient-to-r from-blue-500 to-purple-600 rounded-full font-bold hover:scale-105 transition-transform">Play Again</button>
        </div>
    </div>

    <div class="min-h-screen flex flex-col items-center justify-center p-4">
        <header class="mb-3 text-center">
            <h1 class="text-2xl md:text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500">Chess Master</h1>
            <div class="mt-2 flex items-center justify-center gap-4">
                <a href="/match-history?matchId=<%= locals.matchId %>" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors underline underline-offset-4">Match History</a>
                <div class="flex items-center gap-2 px-3 py-1 rounded-lg bg-zinc-800/60 border border-zinc-700/50">
                    <span class="text-[10px] text-zinc-500 uppercase tracking-wider">Room</span>
                    <span id="room-id-text" class="text-xs font-mono text-blue-400"><%= locals.matchId %></span>
                    <button onclick="copyRoomId()" id="copy-btn" class="text-[10px] px-2 py-0.5 rounded bg-zinc-700 hover:bg-zinc-600 text-zinc-300 transition-colors">Copy</button>
                </div>
            </div>
        </header>

        <div class="mb-3 flex gap-6 text-base font-mono font-bold tracking-wider">
            <div id="white-timer" class="px-3 py-1 rounded bg-white text-black shadow-[0_0_15px_rgba(255,255,255,0.3)]">White: 05:00</div>
            <div id="black-timer" class="px-3 py-1 rounded bg-black text-white border border-zinc-700 shadow-[0_0_15px_rgba(0,0,0,0.5)]">Black: 05:00</div>
        </div>

        <div class="w-full flex flex-col md:flex-row items-center md:items-start justify-center gap-4" style="max-width: 900px;">
            <!-- Chessboard Container -->
            <div class="glass-panel" style="max-width: min(65vh, 480px); flex-shrink: 0;">
                <div class="chessboard"></div>
            </div>

            <!-- Move History Sidebar -->
            <div class="glass-panel flex flex-col" style="max-width: 220px; width: 100%; height: min(65vh, 480px);">
                <h3 class="text-sm font-bold uppercase tracking-widest mb-3 text-center text-zinc-400">Move History</h3>
                <div id="move-history" class="flex-1 overflow-y-auto pr-2 custom-scrollbar">
                    <div class="grid grid-cols-[30px_1fr_1fr] gap-x-2 gap-y-1 text-sm font-mono" id="history-content">
                        <!-- Moves will be injected here -->
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 flex justify-center">
            <!-- Game Info Bottom -->
            <div id="game-info" class="flex flex-wrap justify-center gap-3 text-xs font-semibold uppercase tracking-wider">
                <div id="role-display" class="px-3 py-1.5 rounded-lg bg-zinc-800/50 border border-zinc-700/50 backdrop-blur-md shadow-lg min-w-[100px] text-center">Connecting...</div>
                <div id="turn-display" class="px-3 py-1.5 rounded-lg bg-zinc-800/50 border border-zinc-700/50 backdrop-blur-md shadow-lg min-w-[100px] text-center">Waiting...</div>
                <div id="spectator-display" class="px-3 py-1.5 rounded-lg bg-zinc-800/50 border border-zinc-700/50 backdrop-blur-md shadow-lg min-w-[90px] text-center">Spectators: 0</div>
            </div>
        </div>

        <footer class="mt-8 text-zinc-500 text-xs">
            Developed by Sarthak❤️ for Chess Lovers.
        </footer>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/chess.js/0.10.3/chess.min.js" integrity="sha512-xRllwz2gdZciIB+AkEbeq+gVhX8VB8XsfqeFbUh+SzHlN96dEduwtTuVuc2u9EROlmW9+yhRlxjif66ORpsgVA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="/javascripts/chess_Game.js"></script>
    <script>
        socket.on("playerRole", function (role) {
            document.getElementById("role-display").innerText = "Role: " + (role === "w" ? "White" : "Black");
        });
        socket.on("spectatorRole", function () {
            document.getElementById("role-display").innerText = "Role: Spectator";
        });
        socket.on("spectatorCount", function (count) {
            document.getElementById("spectator-display").innerText = "Spectators: " + count;
        });
        function copyRoomId() {
            const id = document.getElementById('room-id-text').innerText;
            navigator.clipboard.writeText(id).then(() => {
                const btn = document.getElementById('copy-btn');
                btn.innerText = 'Copied!';
                setTimeout(() => btn.innerText = 'Copy', 1500);
            });
        }
    </script>
    <% } else { %>
    <div class="min-h-screen flex flex-col items-center justify-center p-4">
        <div class="glass-panel text-center p-8 w-full max-w-md">
            <h1 class="text-4xl md:text-5xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500 mb-2">Chess Master</h1>
            <p class="text-zinc-400 mb-8 text-sm md:text-base">Real-time multiplayer chess</p>
            
            <div class="flex gap-4 mb-6">
                <button onclick="createGame()" class="flex-1 px-4 py-4 bg-gradient-to-r from-blue-500 to-purple-600 rounded-xl font-bold hover:scale-105 transition-all text-white shadow-lg shadow-blue-500/20 text-lg">
                    Private Room
                </button>
                <button id="quick-match-btn" onclick="quickMatch()" class="flex-1 px-4 py-4 bg-gradient-to-r from-emerald-500 to-teal-600 rounded-xl font-bold hover:scale-105 transition-all text-white shadow-lg shadow-emerald-500/20 text-lg">
                    Quick Match
                </button>
            </div>
            
            <div class="flex items-center gap-4 mb-6 relative">
                <hr class="flex-grow border-zinc-700/50">
                <span class="text-zinc-500 text-xs font-semibold uppercase tracking-wider bg-[#1a1a1a] px-3 absolute left-1/2 -translate-x-1/2 rounded-full">Join Room</span>
                <hr class="flex-grow border-zinc-700/50">
            </div>
            
            <div class="flex flex-col gap-3">
                <input type="text" id="join-match-id" placeholder="Paste Match ID here..." class="w-full px-4 py-4 rounded-xl bg-zinc-800/50 border border-zinc-700 text-white placeholder-zinc-500 focus:outline-none focus:border-blue-500 focus:bg-zinc-800 transition-all text-center font-mono text-lg">
                <button onclick="joinGame()" class="w-full px-6 py-4 bg-zinc-700 hover:bg-zinc-600 rounded-xl font-bold transition-colors text-white text-lg">Join Game</button>
            </div>

            <div class="mt-8">
                <a href="/match-history" class="text-sm border border-zinc-700/50 rounded-full px-6 py-2 text-zinc-400 hover:text-white hover:bg-zinc-800 transition-all inline-block">&larr; View Match History</a>
            </div>
        </div>
    </div>
    <!-- Share ID Modal -->
    <div id="share-modal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md z-[110] flex items-center justify-center">
        <div class="modal-content">
            <h2 class="text-xl font-bold mb-2 text-white">Room Created!</h2>
            <p class="text-zinc-400 text-sm mb-4">Share this ID with your friend or spectators:</p>
            <div class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-zinc-800 border border-zinc-700 mb-4">
                <span id="share-id" class="text-xl font-mono text-blue-400"></span>
                <button onclick="copyShareId()" id="share-copy-btn" class="px-3 py-1 rounded bg-zinc-700 hover:bg-zinc-600 text-sm text-zinc-300 transition-colors">Copy</button>
            </div>
            <button onclick="goToMatch()" class="px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-600 rounded-xl font-bold hover:scale-105 transition-all text-white">Enter Game &rarr;</button>
        </div>
    </div>
    <script>
        const socket = io();
        let pendingMatchId = null;
        
        function quickMatch() {
            const btn = document.getElementById('quick-match-btn');
            btn.innerText = "Searching...";
            btn.disabled = true;
            btn.classList.add("animate-pulse");
            socket.emit("quickMatch");
        }
        
        socket.on("matchFound", function(matchId) {
            window.location.href = '/?matchId=' + matchId;
        });

        function createGame() {
            pendingMatchId = Math.random().toString(36).substring(2, 8);
            document.getElementById('share-id').innerText = pendingMatchId;
            document.getElementById('share-modal').classList.remove('hidden');
        }
        function goToMatch() {
            if (pendingMatchId) window.location.href = '/?matchId=' + pendingMatchId;
        }
        function copyShareId() {
            navigator.clipboard.writeText(pendingMatchId).then(() => {
                const btn = document.getElementById('share-copy-btn');
                btn.innerText = 'Copied!';
                setTimeout(() => btn.innerText = 'Copy', 1500);
            });
        }
        function joinGame() {
            const id = document.getElementById('join-match-id').value.trim();
            if (id) {
                window.location.href = '/?matchId=' + id;
            } else {
                alert('Please enter a valid Match ID');
            }
        }
        document.getElementById('join-match-id').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') joinGame();
        });
    </script>
    <% } %>
</body>
</html>
